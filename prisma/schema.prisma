generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("viewer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Letter {
  id        String   @id @default(cuid())
  title     String
  content   String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Photo {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  caption      String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Song {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  title        String?
  artist       String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Video {
  id         String   @id @default(cuid())
  youtubeUrl String
  youtubeId  String
  title      String?
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model CanvasPage {
  id        String          @id @default(cuid())
  name      String
  published Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  elements  CanvasElement[]
}

model CanvasElement {
  id        String      @id @default(cuid())
  pageId    String
  page      CanvasPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String
  x         Float      @default(0)
  y         Float      @default(0)
  width     Float      @default(200)
  height    Float      @default(200)
  rotation  Float      @default(0)
  zIndex    Int        @default(1)
  content   String?
  refId     String?
  createdAt DateTime   @default(now())
}

model Whisper {
  id        String   @id @default(uuid())
  author    String
  message   String
  createdAt DateTime @default(now())
}

model TimelineEvent {
  id        String   @id @default(cuid())
  title     String
  date      String
  description String?
  icon      String   @default("heart")
  createdAt DateTime @default(now())
}

model DreamJournal {
  id          String   @id @default(uuid())
  title       String
  content     String
  mood        String   @default("místico")
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LoveNote {
  id          String   @id @default(uuid())
  title       String
  message     String
  color       String   @default("gold")
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LoveLock {
  id          String   @id @default(uuid())
  names       String
  message     String
  date        String?
  color       String   @default("gold")
  createdAt   DateTime @default(now())
}
