# Database (SQLite local)
DATABASE_URL=file:./db/custom.db

# Database (Turso / Vercel) — set these in Vercel env vars:
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# JWT Secret — cambia esto por algo random en producción!
# puedes generar uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia-esto-por-algo-secreto
